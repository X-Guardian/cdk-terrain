        "@types/scheduler",
        "@types/semver",
        "@types/stream-buffers",
        "@types/uuid",
        "cdktn",
        "chalk",
        "chokidar",
        "cli-spinners",
        "codemaker",
        "constructs",
        "cross-fetch",
        "detect-port",
        "esbuild",
