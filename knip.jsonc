    "packages/@cdktn/commons": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": [
        // TODO: triage and remove entries — each is a declared dep with no detected usage.
        "@sentry/node",
        "@types/follow-redirects",
        "@types/uuid",
        "@types/validator",
        "cdktn",
        "ci-info",
