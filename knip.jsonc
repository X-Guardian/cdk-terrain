{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  // Check both unused declared deps AND undeclared-but-imported (unlisted) deps.
  "include": ["dependencies", "unlisted"],
  "ignoreWorkspaces": ["examples/**"],
  "workspaces": {
    ".": {
      "ignoreDependencies": [
        // TODO: triage and remove entries — each is a declared dep with no detected usage.
        "changelog-parser",
        "eslint-plugin-import",
        "infer-owner",
        "semver",
        // TODO: triage and add to package.json — each is imported but undeclared.
        "@typescript-eslint/parser",
        "@typescript-eslint/eslint-plugin",
        "@eslint/js"
      ]
    },
    "packages/cdktn": {
      "entry": ["lib/index.ts"],
      "project": ["lib/**/*.ts", "test/**/*.ts"],
      "ignoreDependencies": [
        // TODO: triage and remove entries — each is a declared dep with no detected usage.
        "@types/json-stable-stringify",
        "@types/minimatch",
        "@types/semver",
        "jsii-docgen",
        "json-stable-stringify",
        "semver",
        "yazl"
      ]
    },
    "packages/cdktn-cli": {
      "entry": ["src/bin/cdktn.ts"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": [
        // TODO: triage and remove entries — each is a declared dep with no detected usage.
        "@cdktn/hcl-tools",
        "@cdktn/hcl2json",
        "@skorfmann/ink-confirm-input",
        "@skorfmann/terraform-cloud",
        "@types/archiver",
