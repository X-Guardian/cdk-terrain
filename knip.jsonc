        "execa",
        "extract-zip",
        "follow-redirects",
        "https-proxy-agent",
        "indent-string",
        "ink",
        "ink-select-input",
        "ink-spinner",
        "ink-testing-library",
        "ink-use-stdout-dimensions",
        "jsii",
        "jsii-pacmak",
