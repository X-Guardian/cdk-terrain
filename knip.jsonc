        "@types/detect-port",
        "@types/ink-spinner",
        "@types/json-schema",
        "@types/lodash.isequal",
        "@types/nock",
        "@types/parse-gitignore",
        "@types/stream-buffers",
        "cdktn",
        "chokidar",
        "ci-info",
        "cli-spinners",
        "codemaker",
        "constructs",
        "cross-fetch",
        "cross-spawn",
        "detect-port",
        "esbuild",
        "esbuild-jest",
        "eslint-plugin-react-hooks",
        "https-proxy-agent",
        "indent-string",
        "ink-use-stdout-dimensions",
        "jsii",
        "jsii-pacmak",
        "jsii-rosetta",
        "lodash.isequal",
        "log4js",
        "minimatch",
        "node-fetch",
        "parse-gitignore",
        "sscaff",
        "stream-buffers",
        "tunnel-agent",
        "utility-types",
        "xml-js",
        "yoga-layout-prebuilt",
        "zod",
        // TODO: triage and add to package.json — each is imported but undeclared.
        "@typescript-eslint/parser",
        "@cdktn/provider-schema",
        "@npmcli/ci-detect",
        "glob"
      ]
    },
    "packages/@cdktn/cli-core": {
      "entry": ["src/lib/index.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": [
        // TODO: triage and remove entries — each is a declared dep with no detected usage.
        "@cdktn/hcl-tools",
        "@cdktn/hcl2json",
        "@cdktn/provider-generator",
        "@cdktn/provider-schema",
        "@npmcli/ci-detect",
        "@sentry/node",
        "@skorfmann/ink-confirm-input",
        "@skorfmann/terraform-cloud",
        "@types/detect-port",
        "@types/follow-redirects",
