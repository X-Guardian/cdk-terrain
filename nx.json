{
  "namedInputs": {
    "default": ["{projectRoot}/**/*"],
    "production": [
      "default",
      "!{projectRoot}/**/*.test.ts",
      "!{projectRoot}/**/__tests__/**",
      "!{projectRoot}/tsconfig.test.json"
    ]
  },
  "plugins": [
    {
      "plugin": "@nx/eslint/plugin",
      "options": {
        "targetName": "lint"
      }
    },
    {
      "plugin": "@nx/jest/plugin",
      "options": {
        "targetName": "test"
      }
    }
  ],
  "targetDefaults": {
    "lint": {
      "options": {
        "max-warnings": 0
      }
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "outputs": [
        "{projectRoot}/build",
        "{projectRoot}/.jsii"
      ],
      "cache": true
    },
    "package": {
      "dependsOn": ["build"],
      "inputs": ["production", "^production"],
      "outputs": ["{projectRoot}/dist"],
      "cache": true
    },
    "test": {
      "dependsOn": [
        "build",
        "^build"
      ]
    },
    "test:update": {
      "dependsOn": [
        "build",
        "^build"
      ]
    }
  }
}
