{
  "name": "cdktn-cli",
  "version": "0.0.0",
  "description": "CDK Terrain CLI",
  "bin": {
    "cdktn": "bundle/bin/cdktn"
  },
  "scripts": {
    "compile-build-config": "tsc build.ts",
    "prebuild": "yarn compile-build-config",
    "build": "tsc --noEmit",
    "postbuild": "node build.js",
    "watch": "yarn compile-build-config && node build.js --watch",
    "watch-preserve-output": "yarn watch",
    "pretest": "yarn build",
    "pretest:ci": "yarn build",
    "test": "jest",
    "test:ci": "jest --ci",
    "test:update": "jest -u",
    "jest-watch": "jest --watch",
    "package": "./package.sh",
    "package:js": "./package.sh",
    "dist-clean": "rm -rf dist"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/open-constructs/cdk-terrain.git",
    "directory": "packages/cdktn-cli"
  },
  "author": {
    "name": "OpenConstructs",
    "url": "https://github.com/open-constructs"
  },
  "keywords": [
    "cdk",
    "cdktf",
    "cdktn",
    "terraform"
  ],
  "license": "MPL-2.0",
  "files": [
    "bundle"
  ],
  "dependencies": {
    "@types/node": "20.19.1",
    "constructs": "10.6.0"
  },
  "peerDependencies": {
    "@cdktn/hcl-tools": "0.0.0",
    "@cdktn/hcl2cdk": "0.0.0",
    "@cdktn/hcl2json": "0.0.0",
    "cdktn": "0.0.0",
    "jsii": "5.9.37",
    "jsii-pacmak": "1.128.0",
    "yargs": "17.7.2",
    "yoga-layout-prebuilt": "1.10.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "tsc-files ambient.d.ts --noEmit",
      "eslint"
    ]
  },
  "devDependencies": {
    "@cdktn/cli-core": "0.0.0",
    "@cdktn/commons": "0.0.0",
    "@cdktn/provider-generator": "0.0.0",
    "@cdktn/provider-schema": "0.0.0",
    "@inquirer/prompts": "2.3.1",
    "@npmcli/ci-detect": "1.4.0",
    "@sentry/node": "7.120.4",
    "@types/fs-extra": "8.1.5",
    "@types/jest": "30.0.0",
    "@types/pidusage": "2.0.5",
    "@types/react": "18.3.28",
    "@types/semver": "7.7.1",
    "@types/uuid": "8.3.4",
    "@types/yargs": "17.0.35",
    "chalk": "4.1.2",
    "esbuild": "^0.28.0",
    "execa": "5.1.1",
    "extract-zip": "2.0.1",
    "fs-extra": "8.1.0",
    "glob": "10.5.0",
    "ink": "3.2.0",
    "ink-select-input": "4.2.2",
    "ink-spinner": "4.0.3",
    "ink-table": "3.1.0",
    "ink-testing-library": "2.1.0",
    "jest": "^30.3.0",
    "nock": "13.5.6",
    "open": "7.4.2",
    "pidtree": "0.6.0",
    "pidusage": "3.0.2",
    "pkg-up": "3.1.0",
    "react": "18.3.1",
    "semver": "7.7.4",
    "strip-ansi": "6.0.1",
    "ts-jest": "29.4.9",
    "tsc-files": "1.1.4",
    "typescript": "5.4.5",
    "uuid": "8.3.2"
  }
}
