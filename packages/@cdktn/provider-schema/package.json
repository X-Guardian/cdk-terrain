{
  "name": "@cdktn/provider-schema",
  "version": "0.0.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "CDK Terrain utilities to work with provider schemas",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "watch-preserve-output": "tsc -w --preserveWatchOutput",
    "lint": "eslint . ",
    "lint:fix": "eslint . --fix",
    "pretest": "yarn build",
    "pretest:ci": "yarn build",
    "test": "jest",
    "test:ci": "jest --ci",
    "test:update": "jest -u",
    "jest-watch": "jest --watch",
    "package": "./package.sh",
    "dist-clean": "rm -rf dist",
    "package:js": "./package.sh"
  },
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git://github.com/open-constructs/cdk-terrain.git",
    "directory": "packages/@cdktn/provider-schema"
  },
  "author": {
    "name": "OpenConstructs",
    "url": "https://github.com/open-constructs"
  },
  "keywords": [
    "cdk",
    "cdktf",
    "cdktn",
    "terraform"
  ],
  "license": "MPL-2.0",
  "dependencies": {
    "@cdktn/commons": "0.0.0",
    "@cdktn/hcl2json": "0.0.0",
    "deepmerge": "4.3.1",
    "fs-extra": "11.3.4"
  },
  "devDependencies": {
    "@types/fs-extra": "11.0.4",
    "@types/json-stable-stringify": "1.2.0",
    "jest": "^30.3.0",
    "json-stable-stringify": "1.3.0",
    "ts-jest": "29.4.9",
    "tsc-files": "1.1.4",
    "typescript": "5.4.5"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": "tsc-files ambient.d.ts --noEmit"
  }
}
