{
  "name": "@cdktn/cli-core",
  "version": "0.0.0",
  "description": "CDK Terrain CLI Core, meant for internal use only",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "watch-preserve-output": "tsc -w --preserveWatchOutput",
    "pretest": "pnpm run build",
    "pretest:ci": "pnpm run build",
    "test": "jest",
    "test:ci": "jest --ci",
    "test:update": "jest -u --maxWorkers=50%",
    "jest-watch": "jest --watch",
    "package": "./package.sh",
    "dist-clean": "rm -rf dist",
    "package:js": "./package.sh"
  },
  "main": "build/lib/index.js",
  "types": "build/lib/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/open-constructs/cdk-terrain.git",
    "directory": "packages/@cdktn/cli-core"
  },
  "author": {
    "name": "OpenConstructs",
    "url": "https://github.com/open-constructs"
  },
  "keywords": [
    "cdk",
    "cdktf",
    "cdktn",
    "terraform"
  ],
  "license": "MPL-2.0",
  "dependencies": {
    "@cdktn/commons": "workspace:*",
    "@cdktn/hcl-tools": "workspace:*",
    "@cdktn/hcl2cdk": "workspace:*",
    "@cdktn/provider-schema": "workspace:*",
    "@sentry/node": "7.120.4",
    "cdktn": "workspace:*",
    "chalk": "4.1.2",
    "chokidar": "3.6.0",
    "ci-info": "3.9.0",
    "codemaker": "1.128.0",
    "constructs": "10.6.0",
    "cross-spawn": "7.0.6",
    "fs-extra": "8.1.0",
    "https-proxy-agent": "5.0.1",
    "indent-string": "4.0.0",
    "minimatch": "5.1.9",
    "node-fetch": "2.7.0",
    "pkg-up": "3.1.0",
    "semver": "7.7.4",
    "sscaff": "1.2.274",
    "strip-ansi": "6.0.1",
    "xml-js": "1.6.11",
    "xstate": "4.38.3",
    "zod": "3.25.76"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": "tsc-files ambient.d.ts --noEmit"
  },
  "devDependencies": {
    "@cdktn/provider-generator": "workspace:*",
    "@types/cross-spawn": "6.0.6",
    "@types/fs-extra": "8.1.5",
    "@types/jest": "30.0.0",
    "@types/minimatch": "5.1.2",
    "@types/node": "20.19.1",
    "@types/node-fetch": "2.6.13",
    "@types/semver": "7.7.1",
    "jest": "^30.3.0",
    "nock": "13.5.6",
    "prettier": "2.8.8",
    "ts-jest": "29.4.9",
    "tsc-files": "1.1.4",
    "typescript": "5.4.5"
  }
}
