{
  "name": "@cdktn/provider-generator",
  "version": "0.0.0",
  "description": "Exposes API to generate Terraform CDK provider bindings",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "node ./build/__tests__/edge-provider-schema/cli.js ./edge-provider-bindings",
    "watch": "tsc -w",
    "watch-preserve-output": "tsc -w --preserveWatchOutput",
    "test": "jest",
    "test:ci": "jest --ci",
    "test:update": "jest -u",
    "jest-watch": "jest --watch",
    "package": "./package.sh",
    "dist-clean": "rm -rf dist",
    "package:js": "./package.sh"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/open-constructs/cdk-terrain.git",
    "directory": "packages/@cdktn/provider-generator"
  },
  "author": {
    "name": "OpenConstructs",
    "url": "https://github.com/open-constructs"
  },
  "keywords": [
    "cdk",
    "cdktf",
    "cdktn",
    "terraform"
  ],
  "license": "MPL-2.0",
  "dependencies": {
    "@cdktn/commons": "0.0.0",
    "@cdktn/provider-schema": "0.0.0",
    "codemaker": "1.128.0",
    "fs-extra": "8.1.0",
    "glob": "10.5.0",
    "jsii": "5.9.37",
    "jsii-pacmak": "1.128.0"
  },
  "devDependencies": {
    "@types/fs-extra": "8.1.5",
    "@types/jest": "30.0.0",
    "@types/node": "20.19.37",
    "jest": "^30.3.0",
    "ts-jest": "29.4.9",
    "typescript": "5.4.5"
  }
}
