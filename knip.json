{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "include": ["dependencies"],
  "ignoreWorkspaces": [
    "examples/**"
  ],
  "workspaces": {
    "packages/cdktn": {
      "entry": ["lib/index.ts"],
      "project": ["lib/**/*.ts", "test/**/*.ts"]
    },
    "packages/cdktn-cli": {
      "entry": ["src/bin/cdktn.ts", "build.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/@cdktn/cli-core": {
      "entry": ["src/lib/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/@cdktn/commons": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/@cdktn/hcl-tools": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/@cdktn/hcl2cdk": {
      "entry": ["lib/index.ts"],
      "project": ["lib/**/*.ts", "test/**/*.ts"]
    },
    "packages/@cdktn/hcl2json": {
      "entry": ["lib/index.ts"],
      "project": ["lib/**/*.ts", "test/**/*.ts"]
    },
    "packages/@cdktn/provider-generator": {
      "entry": ["lib/index.ts"],
      "project": ["lib/**/*.ts"]
    },
    "packages/@cdktn/provider-schema": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "tools/generate-function-bindings": {
      "project": ["scripts/**/*.ts"]
    }
  }
}
